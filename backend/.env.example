# Copy this file to .env and fill in your real values

# Google Gemini API key - get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# Local SQLite database (works without Docker). For Postgres, replace this with:
# postgresql://postgres:postgres@localhost:5432/meeting_ai
DATABASE_URL=sqlite:///./meeting_ai.db

# Whisper model size: tiny, base, small, medium, large-v3
# "small" is a good MVP balance of speed/accuracy on a laptop CPU
# "large-v3" is best quality but needs a GPU to run fast
WHISPER_MODEL_SIZE=small

# Where uploaded audio files get stored on disk (Phase 1 - no S3 yet)
UPLOAD_DIR=./uploads

# Comma-separated list of frontend origins allowed to call this API.
# Add your deployed frontend domain(s) here, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://app.orivon.example
CORS_ORIGINS=http://localhost:3000

# Maximum accepted audio upload size, in megabytes
MAX_UPLOAD_MB=200

# Python logging level for the structured JSON logs (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Per-IP rate limits (requests per minute) for upload and AI-backed endpoints
RATE_LIMIT_ENABLED=true
RATE_LIMIT_UPLOAD_PER_MINUTE=10
RATE_LIMIT_AI_PER_MINUTE=20

# Default/maximum page size for GET /meetings pagination
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=200

# Secret used to sign access/media JWTs and hash refresh tokens. If unset,
# a random one is generated per process (fine for local dev; it just means
# every restart invalidates existing sessions). Set this explicitly in
# production, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
MEDIA_TOKEN_EXPIRE_MINUTES=120

# Set to true once this API is served over HTTPS in production - the
# refresh token cookie should never be sent over plain HTTP there.
COOKIE_SECURE=false

# Google "Sign in with Google" client ID (from Google Cloud Console). Leave
# empty to disable Google sign-in entirely - the frontend hides the button.
GOOGLE_CLIENT_ID=
