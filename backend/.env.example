# Copy this file to .env and fill in your real values

# Google Gemini API key - get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Local SQLite database (works without Docker). For Postgres, replace this with:
# postgresql://postgres:postgres@localhost:5432/meeting_ai
DATABASE_URL=sqlite:///./meeting_ai.db

# Whisper model size: tiny, base, small, medium, large-v3
# "small" is a good MVP balance of speed/accuracy on a laptop CPU
# "large-v3" is best quality but needs a GPU to run fast
WHISPER_MODEL_SIZE=small

# Where uploaded audio files get stored on disk (Phase 1 - no S3 yet)
UPLOAD_DIR=./uploads
